ARG COFI_VERSION="latest"
ARG COFI_EXAMPLES_VERSION="latest"
ARG COFI_INSTALL_SOURCE="pypi"
ARG COFI_REF="main"

FROM ubuntu:24.04 AS ubuntu-python

SHELL ["/bin/bash", "-euxo", "pipefail", "-c"]

ARG NB_UID=1000
ARG NB_GID=1000

ENV DEBIAN_FRONTEND=noninteractive \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    TMPDIR=/opt/build-tmp \
    TMP=/opt/build-tmp \
    TEMP=/opt/build-tmp

RUN mkdir -p /opt/build-tmp \
 && chmod 1777 /opt/build-tmp \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      hostname \
      wget \
      bzip2 \
      git \
      patch \
      which \
      curl \
      unzip \
      tar \
      gzip \
      findutils \
      diffutils \
      build-essential \
      gfortran \
      make \
      cmake \
      ninja-build \
      python3.12 \
      python3.12-dev \
      python3.12-venv \
      python3-pip \
      libproj-dev \
      libgeos-dev \
      zlib1g-dev \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/* \
 && ln -sf /usr/bin/python3.12 /usr/local/bin/python3 \
 && ln -sf /usr/bin/python3.12 /usr/local/bin/python \
 && if getent passwd "${NB_UID}" >/dev/null; then userdel -r "$(getent passwd "${NB_UID}" | cut -d: -f1)"; fi \
 && if getent group "${NB_GID}" >/dev/null; then groupdel "$(getent group "${NB_GID}" | cut -d: -f1)"; fi \
 && groupadd --gid "${NB_GID}" jovyan \
 && useradd --create-home --shell /bin/bash --uid "${NB_UID}" --gid "${NB_GID}" jovyan

RUN python -m pip install --upgrade --ignore-installed pip setuptools wheel \
 && python -m pip install numpy matplotlib scipy

COPY image/scripts/install-cofi.sh /usr/local/bin/install-cofi.sh
COPY image/scripts/install-seislib.sh /usr/local/bin/install-seislib.sh
COPY image/scripts/install-cofi-paper-deps.sh /usr/local/bin/install-cofi-paper-deps.sh
COPY image/scripts/install-inlab-python-packages.sh /usr/local/bin/install-inlab-python-packages.sh
COPY image/scripts/install-pygimli.sh /usr/local/bin/install-pygimli.sh
COPY image/scripts/install-pygimli-pip.sh /usr/local/bin/install-pygimli-pip.sh

RUN chmod +x \
      /usr/local/bin/install-cofi.sh \
      /usr/local/bin/install-seislib.sh \
      /usr/local/bin/install-cofi-paper-deps.sh \
      /usr/local/bin/install-inlab-python-packages.sh \
      /usr/local/bin/install-pygimli.sh \
      /usr/local/bin/install-pygimli-pip.sh

FROM ubuntu-python AS cofi-examples-src

ARG COFI_EXAMPLES_VERSION
ARG COFI_EXAMPLES_REPO="https://github.com/inlab-geo/cofi-examples.git"

# COFI_EXAMPLES_VERSION already pins an exact commit/tag (see versions.txt),
# so a plain archive download gets the same content as a git clone without
# ever materialising .git history (measured at 151MB via the old clone-based
# approach) into any layer a runtime image copies from.
RUN set -eux; \
    ref="${COFI_EXAMPLES_VERSION}"; \
    if [ "${ref}" = "latest" ]; then ref="main"; fi; \
    archive_url="${COFI_EXAMPLES_REPO%.git}/archive/${ref}.tar.gz"; \
    mkdir -p /tmp/repo /tmp/cofi-view /tmp/inlab-view; \
    curl -fsSL "${archive_url}" | tar xz -C /tmp/repo --strip-components=1; \
    cp -a /tmp/repo/cofi-paper /tmp/cofi-view/; \
    cp -a /tmp/repo/LICENCE /tmp/repo/index.ipynb /tmp/cofi-view/ 2>/dev/null || true; \
    cp -a /tmp/repo/. /tmp/inlab-view/; \
    rm -rf /tmp/inlab-view/tools /tmp/inlab-view/envs /tmp/inlab-view/.github \
           /tmp/inlab-view/README.md /tmp/inlab-view/CONTRIBUTING.md \
           /tmp/inlab-view/examples/pygimli_dcip/archived \
           /tmp/inlab-view/examples/pygimli_ert/archived \
           /tmp/inlab-view/examples/more_scripts

FROM ubuntu-python AS cofi

ARG COFI_VERSION
ARG COFI_INSTALL_SOURCE
ARG COFI_REF

RUN /usr/local/bin/install-cofi.sh

COPY --from=cofi-examples-src --chown=jovyan:jovyan /tmp/cofi-view /home/jovyan/cofi-examples

RUN /usr/local/bin/install-cofi-paper-deps.sh

ENV JOBLIB_MULTIPROCESSING=0 \
    OMP_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    NUMEXPR_NUM_THREADS=1

USER jovyan
WORKDIR /home/jovyan/cofi-examples/cofi-paper
EXPOSE 2718

CMD ["marimo", "edit", "--host", "0.0.0.0", "--port", "2718"]

FROM cofi AS inlab

USER root

ARG COFI_VERSION
ARG COFI_INSTALL_SOURCE
ARG COFI_REF

# PyGIMLi's compiled backend (pgcore) only ships manylinux_x86_64 wheels on
# PyPI, so amd64 installs via pip while arm64 (no aarch64 wheel available)
# keeps building from source, same as the Triangle CFLAGS split below.
RUN apt-get update \
 && if [ "$(uname -m)" = "x86_64" ] || [ "$(uname -m)" = "amd64" ]; then \
      EXTRA_PKGS=""; \
    else \
      EXTRA_PKGS="subversion mercurial castxml pandoc clang libboost-all-dev libedit-dev libsuitesparse-dev libopenblas-openmp-dev libumfpack6 libomp-dev libcppunit-dev"; \
    fi \
 && apt-get install -y --no-install-recommends vim $EXTRA_PKGS \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

ENV PYTHONPATH=/opt/gimli/gimli \
    LD_LIBRARY_PATH=/opt/gimli/build/lib \
    PATH=/opt/gimli/build/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN if [ "$(uname -m)" = "x86_64" ] || [ "$(uname -m)" = "amd64" ]; then \
      /usr/local/bin/install-pygimli-pip.sh; \
    else \
      /usr/local/bin/install-pygimli.sh; \
    fi \
 && /usr/local/bin/install-inlab-python-packages.sh

RUN if [ "$(uname -m)" != "x86_64" ] && [ "$(uname -m)" != "amd64" ]; then python -m pip install --no-deps -e /opt/gimli/gimli; fi

COPY --from=cofi-examples-src --chown=jovyan:jovyan /tmp/inlab-view /home/jovyan/cofi-examples

RUN mkdir -p /home/jovyan/.cache/pygimli \
 && chown -R jovyan:jovyan /home/jovyan/.cache

COPY image/scripts/start.sh /usr/local/bin/start.sh
RUN chmod +x /usr/local/bin/start.sh

USER jovyan
WORKDIR /home/jovyan/cofi-examples
EXPOSE 8888 2718

CMD ["/usr/local/bin/start.sh"]
